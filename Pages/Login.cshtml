@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="columns is-centered">
    <div class="column is-one-third">
        <div class="card">
            <header class="card-header">
                <p class="card-header-title">Login</p>
            </header>
            <div class="card-content">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="has-text-danger"></div>
                    <div class="field">
                        <label asp-for="Input.Email" class="label"></label>
                        <div class="control">
                            <input asp-for="Input.Email" class="input" />
                        </div>
                        <span asp-validation-for="Input.Email" class="help is-danger"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Input.Password" class="label"></label>
                        <div class="control">
                            <input asp-for="Input.Password" type="password" class="input" />
                        </div>
                        <span asp-validation-for="Input.Password" class="help is-danger"></span>
                    </div>
                    <div class="field">
                        <div class="control">
                            <button type="submit" class="button is-primary is-fullwidth">Login</button>
                        </div>
                    </div>
                </form>
            </div>
            <footer class="card-footer">
                <p class="card-footer-item">
                    Don't have an account? <a asp-page="/Register">&nbsp;Register</a>
                </p>
            </footer>
        </div>
    </div>
</div>
